# Copy to .env and fill in your values.
# Each provider can use its own key; profiles in harness/config/agents.toml
# select which env var to read via api_key_env / api_base_env.

# DeepSeek (profiles: deepseek_v4_flash, deepseek_v4_pro)
FEATURELIFTBENCH_API_KEY=
FEATURELIFTBENCH_API_BASE=https://api.deepseek.com/v1

# SiliconFlow (profiles: glm_5_2, kimi_k2_7_code, minimax_m2_5, qwen3_6_27b, nex_n2_pro)
SILICONFLOW_API_KEY=
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1

# Local vLLM (profiles: gpt_oss_120b_vllm, qwen3_coder_30b_vllm,
# openhands_qwen3_next_80b_vllm, openhands_qwen3_coder_30b_vllm)
# When an agent runs in Docker and API_BASE points at 127.0.0.1/localhost,
# set FEATURELIFTBENCH_AGENT_DOCKER_NETWORK=host before running.
VLLM_GPT_OSS_120B_API_KEY=sk-dummy
VLLM_GPT_OSS_120B_API_BASE=http://127.0.0.1:8008/v1

VLLM_QWEN3_NEXT_80B_API_KEY=sk-dummy
VLLM_QWEN3_NEXT_80B_API_BASE=http://127.0.0.1:8008/v1

VLLM_QWEN3_CODER_30B_API_KEY=sk-dummy
VLLM_QWEN3_CODER_30B_API_BASE=http://127.0.0.1:8009/v1
