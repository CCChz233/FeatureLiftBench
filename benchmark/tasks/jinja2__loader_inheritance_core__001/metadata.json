    "included_behaviors": [
      "load templates via DictLoader and BaseLoader subclasses",
      "resolve extends chains and block overrides",
      "render nested block inheritance across multiple templates",
      "support trim_blocks for layout templates"
    ],
    "excluded_behaviors": [
