ARG PYTHON_BASE=python:3.11-slim
FROM ${PYTHON_BASE}

WORKDIR /workspace

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/workspace/harness \
    PIP_NO_CACHE_DIR=1

RUN pip install \
    "pytest==7.4.4" \
    "idna==3.7" \
    "multidict==6.0.4" \
    "propcache==0.4.1"

COPY harness /workspace/harness

ENTRYPOINT ["python", "-B", "-m", "featureliftbench.cli"]
