ARG PYTHON_BASE=python:3.11-slim
FROM ${PYTHON_BASE}

WORKDIR /workspace

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/workspace/harness \
    PIP_NO_CACHE_DIR=1

RUN pip install \
    "pytest==7.4.4" \
    "idna==3.7" \
    "multidict==6.0.4" \
    "propcache==0.4.1"

COPY benchmark/vendor-wheels /workspace/benchmark/vendor-wheels
COPY harness /workspace/harness

ENV PIP_FIND_LINKS=/workspace/benchmark/vendor-wheels

RUN pip install --no-index --find-links /workspace/benchmark/vendor-wheels \
    -r /workspace/harness/config/benchmark_requirements.lock

ENTRYPOINT ["python", "-B", "-m", "featureliftbench.cli"]
