{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FeatureLiftBench task metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "language",
    "source",
    "feature",
    "entanglement",
    "output",
    "environment",
    "tests"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "const": "python" },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url", "commit", "license"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 }
      }
    },
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "source_entrypoints",
        "included_behaviors",
        "excluded_behaviors"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "source_entrypoints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "included_behaviors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "excluded_behaviors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "entanglement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "types", "description", "signals"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "framework_coupling",
              "config_environment_coupling",
              "global_state_registry_coupling",
              "resource_coupling",
              "implicit_dependency_coupling",
              "parser_state_coupling",
              "data_model_coupling",
              "third_party_dependency_coupling",
              "legacy_vibe_clutter"
            ]
          }
        },
        "description": { "type": "string", "minLength": 1 },
        "signals": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "import", "callable", "signature"],
      "properties": {
        "package": { "type": "string", "minLength": 1 },
        "import": { "type": "string", "minLength": 1 },
        "callable": { "type": "string", "minLength": 1 },
        "signature": { "type": "string", "minLength": 1 }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "python",
        "network",
        "timeout_seconds",
        "dependency_lock",
        "allowed_dependencies",
        "forbidden_dependencies",
        "forbidden_imports"
      ],
      "properties": {
        "python": { "type": "string", "minLength": 1 },
        "network": { "type": "boolean" },
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "dependency_lock": { "type": "string", "minLength": 1 },
        "allowed_dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbidden_dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbidden_imports": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public", "hidden", "command"],
      "properties": {
        "public": { "type": "string", "minLength": 1 },
        "hidden": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 }
      }
    },
    "scoring_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "copy_all_bytes",
        "copy_all_loc",
        "oracle_bytes",
        "oracle_loc",
        "oracle_dependency_count"
      ],
      "properties": {
        "copy_all_bytes": { "type": "number", "minimum": 0 },
        "copy_all_loc": { "type": "number", "minimum": 0 },
        "oracle_bytes": { "type": "number", "minimum": 0 },
        "oracle_loc": { "type": "number", "minimum": 0 },
        "oracle_dependency_count": { "type": "number", "minimum": 0 }
      }
    }
  }
}
